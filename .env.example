# RouteBite local environment

# Yelp Fusion API key. Leave empty to use mock restaurants.
# Create one from https://docs.developer.yelp.com/docs/fusion-authentication
YELP_API_KEY=

# Use mock routing for stable local demos. Set false to use OSRM.
USE_MOCK_ROUTING=true

# Use mock geocoding for fully offline demos. Set false to use Nominatim.
USE_MOCK_GEOCODING=true

# Frontend proxy target. Local Next.js defaults to http://localhost:8080.
# In Vercel, set this to your deployed Fly API, for example:
# ROUTEBITE_API_BASE=https://routebite.fly.dev
ROUTEBITE_API_BASE=

# Optional PostgreSQL persistence for /v1/agent/search history.
# Leave disabled for local demos that do not need a database.
DB_ENABLED=false
DATABASE_URL=

# Optional Redis cache for repeated geocoding and restaurant searches.
# Leave disabled for local demos that do not need Redis.
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_MINUTES=15
